<UserControl x:Class="Presentation.WPF.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Presentation.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    
    <Grid>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding TieneCategorias}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>

            <TextBlock Text="No hay productos o categorías, ingresa a configuración de menú para agregarlas." 
                       FontSize="22" 
                       FontWeight="SemiBold"
                       Foreground="Gray"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="600"/>
        </StackPanel>

        <Grid Visibility="{Binding TieneCategorias, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFC107" HorizontalAlignment="Left" CornerRadius="8" Padding="15,5">
                <TextBlock Text="CATEGORIAS" FontSize="24" FontWeight="Bold" Foreground="Black"/>
            </Border>

            <ListBox Grid.Row="1" ItemsSource="{Binding Categorias}" Background="Transparent" BorderThickness="0" Margin="0,20,0,0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" VerticalAlignment="Top"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#D3D3D3" BorderThickness="1.5" CornerRadius="15" Width="180" Height="200" Margin="10" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Image Grid.Row="0" Source="{Binding ImagenUrl}" Stretch="Uniform" MaxHeight="120" Margin="5"/>
                                <TextBlock Grid.Row="1" Text="{Binding Nombre}" FontSize="18" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Foreground="Black"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>
</UserControl>