<UserControl x:Class="Presentation.WPF.Views.Comanda"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Presentation.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="1024" d:DesignWidth="900">

    <Grid Background="AliceBlue">
        
        <!--#region Estructura Inicial-->
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!--#endregion-->
        
        <!--#region Fila Superior ( Boton de retroceso, Categorias)-->
        <Grid Grid.Row="0" >

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

        </Grid>
        <!--#endregion-->
        
        <!--#region Fila Inferior (Comanda, Productos) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--#region Comanda-->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>
                
                <!--#region Fila 0( Titulo, Numero de ticket y boton para eliminar comanda )-->
                <Border Grid.Row="0" Background="White" BorderBrush="Gray" BorderThickness="0,0,0,1">

                    <StackPanel>

                        <TextBlock HorizontalAlignment="Center" FontSize="20"> Comanda </TextBlock>
                        <TextBlock FontSize="16"> Numero de Ticket #</TextBlock>
                        <Image></Image>

                    </StackPanel>
                </Border>
                <!--#endregion-->

                <!--#region Fila 1( Productos que se añaden a la comanda )-->
                <Border Grid.Row="1" Background="White" BorderBrush="Gray" BorderThickness="0,0,0,1">

                </Border>
                <!--#endregion-->

                <!--#region Fila 0( Titulo, Numero de ticket y boton para eliminar comanda )-->
                <Border Grid.Row="2" Background="{StaticResource Fondo}" >

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid ColumnDefinitions="">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"> Total</TextBlock>
                            <Button Grid.Row="1" Background="Transparent">Comentario</Button>

                        </Grid>

                        <Grid ColumnDefinitions="1">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"> $0.00</TextBlock>
                            <Button Grid.Row="1" Background="Transparent">Finalizar</Button>
                        </Grid>


                    </Grid>

                </Border>
                <!--#endregion-->

            </Grid>
            <!--#endregion-->
            
        </Grid>
        <!--#endregion-->
        
    </Grid>
</UserControl>