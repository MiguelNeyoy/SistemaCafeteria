<UserControl x:Class="Presentation.WPF.Views.ConfiguracionMenuViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Presentation.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900">

    <Grid >

        <!--#region Estructura Inicial-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="600" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="Gray"/>
        <Border Grid.Column="1" />
        <!--#endregion-->
        
        <!--#region Columna Izquierda (Total de Productos, Añadir Categoria y Añadir Productos )-->
        <Grid Grid.Column="0">

            <Grid.RowDefinitions>
                <RowDefinition Height="250"/> 
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!--#region Total Productos, Añadir Categorias y Añadir Productos-->
            <Grid Grid.Row="0">

                <!--#region Estilos-->
                <Grid.Resources>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderBrush" Value="Black"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="CornerRadius" Value="10" />
                    </Style>

                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="{StaticResource Fuente-principal}" />
                        <Setter Property="FontSize" Value="24" />

                    </Style>

                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent" />
                    </Style>
                </Grid.Resources>
                <!--#endregion-->
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!--#region Total Productos-->
                <Border Grid.Column="0" Height="170" Width="240">

                    <TextBlock > Total de Productos: </TextBlock>
                    
                </Border>
                <!--#endregion-->
                
                <!--#region Añadir Categoria-->
                <Border Grid.Column="1" Height="170">
                    
                </Border>
                <!--#endregion-->
                
                <!--#region Añadir Producto-->
                <Border Grid.Column="2" Height="170" Width="165">
                    <Grid>
                        <TextBlock Text="Añadir Producto"/>
                        <Image Source="/Assets/Imagenes/Icono de Adicion.png" Height="100" Width="100" VerticalAlignment="Stretch"/>
                        <Button />
                    </Grid>
                </Border>
                <!--#endregion-->

            </Grid>
            <!--#endregion-->
            
            <!--#region Tabla de Categorias y Productos-->
            <Grid Grid.Row="1">

                <Grid.Resources>
                    <Style TargetType="Border">
                        <Setter Property="Height" Value="500"/>
                        <Setter Property="Width" Value="280"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="BorderBrush" Value="Black"/>
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>

                    <Style TargetType="TextBlock">
                        <Setter Property="FontFamily" Value="{StaticResource Fuente-principal}" />
                        <Setter Property="FontSize" Value="28" />
                        <Setter Property="HorizontalAlignment" Value="Center" />
                    </Style>
                </Grid.Resources>
                
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>
                
                <!--#region Categorias-->
                <Border Grid.Column="0">
                    <Grid Height="50" VerticalAlignment="Top">
                        <Border Height="auto" BorderThickness="0,0,0,1" BorderBrush="Black"  CornerRadius="0">
                            <TextBlock Text="Categorias" />
                        </Border>
                    </Grid>
                </Border>
                <!--#endregion-->

                <!--#region Productos-->
                <Border Grid.Column="1">
                    <Grid Height="50" VerticalAlignment="Top">
                        <Border Height="auto" BorderThickness="0,0,0,1" BorderBrush="Black" CornerRadius="0">
                            <TextBlock Text="Productos" />
                        </Border>
                    </Grid>
                </Border>
                <!--#endregion-->

            </Grid>
            <!--#endregion-->
            
        </Grid>
        <!--#endregion-->
        
    </Grid>
</UserControl>