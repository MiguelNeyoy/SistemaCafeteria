<!--
    Este es el punto de entrada de la app es decir esta es la ventana principal y lo que esta en la carpeta de /Views son 
    componentes reutilizables que incrustran aqui en esta ventana principal. 
    
    En esta ventana principal se coloca lo que no cambia en ninguna otra vista como el menu, logos, Botones para minimizar,cerrar y maximizar la app
    cosas que siempre vera el usuario.
-->
<Window x:Class="Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation.WPF"
        mc:Ignorable="d"
        Title=" POS - UNAMORDIDA " Height="1024" Width="1280">



    <Grid>
        <!--#region Estructura Inicial-->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="318" />
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Fondo-lateral-izq}" BorderBrush="Gray" BorderThickness="0,0,1,0" />
        <Border Grid.Column="1" Background="{StaticResource Fondo}" BorderBrush="Gray" />

        <!--#endregion-->


        <!--#region Columna Izquierda (Logotipo y Botones) -->
        <Grid Grid.Column="0" >
            
            <!--#region Tipografia y Tamaño para TextBlock-->
            <Grid.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="FontFamily" Value="Algerian"/>
                    <Setter Property="FontSize" Value="40" />
                </Style>
            </Grid.Resources>
            <!--#endregion-->
            
            <Grid.RowDefinitions>
                <RowDefinition Height = "300" />
                <RowDefinition Height = "181" />
                <RowDefinition Height = "181" />
                <RowDefinition Height = "181" />
                <RowDefinition Height = "181" />
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="0,0,0,1"/>

            <!--#region Botones(Menu,Configuracion de Menu,Cierre de caja y Ventas)-->
            <Border Grid.Row="1">
                <TextBlock Text="MENU"/>
            </Border>

            <Border Grid.Row="2">
                <TextBlock>
                    CONFIGURACION<LineBreak/>DE MENU
                </TextBlock>
            </Border>

            <Border Grid.Row="3">
                <TextBlock Text="CIERRE DE CAJA"/>
            </Border>

            <Border Grid.Row="4">
                <TextBlock Text="VENTAS"/>
            </Border>
            <!--#endregion-->

        </Grid>
        <!--#endregion-->
        
        
        <!--#region Caja Superior (Categorias, Fecha)-->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height = "180" />
            </Grid.RowDefinitions>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,0,1" />

        </Grid>
        <!--#endregion-->

    </Grid>

</Window>